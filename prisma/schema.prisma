generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
  PAUSED
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription         Subscription?
  usage                Usage[]
  performanceAudits    PerformanceFixerAudit[]
  contentOptimizations ContentOptimization[]
  clients              Client[]              @relation("AgencyClients")
  reportTemplates      ReportTemplate[]      @relation("ReportTemplates")
  contentIdeaProjects  ContentIdeaProject[]  @relation("ContentIdeaProjects")
  competitorAnalyses   CompetitorAnalysis[]  @relation("CompetitorAnalyses")
  competitorComparisons CompetitorComparison[] @relation("CompetitorComparisons")

  @@index([clerkId])
}

model Client {
  id       String @id @default(cuid())
  agencyId String
  agency   User   @relation("AgencyClients", fields: [agencyId], references: [id], onDelete: Cascade)

  name     String
  email    String
  website  String
  industry String?

  reportTemplate String @default("standard")
  brandColor     String @default("#6366f1")
  logoUrl        String?

  trackKeywords String @db.Text
  competitors   String @db.Text

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  reports   ClientReport[]

  @@index([agencyId])
}

model ClientReport {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  month Int
  year  Int

  keywordRankings String @db.Text
  trafficChange   Int
  backlinksAdded  Int
  topPerformers   String @db.Text

  domainAuthority Float @default(45)
  pageAuthority   Float @default(52)
  backlinksTotal  Int   @default(500)

  reportHtml   String    @db.Text
  reportPdfUrl String?

  emailSent      Boolean   @default(false)
  emailSentAt    DateTime?
  clientViewed   Boolean   @default(false)
  clientViewedAt DateTime?

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([month])
}

model ReportTemplate {
  id       String @id @default(cuid())
  agencyId String
  agency   User   @relation("ReportTemplates", fields: [agencyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  sections    String  @db.Text
  customText  String? @db.Text
  footerText  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  paddleSubscriptionId String             @unique
  paddleCustomerId     String
  paddlePriceId        String
  paddleTransactionId  String?
  status               SubscriptionStatus @default(ACTIVE)
  plan                 Plan
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([paddleSubscriptionId])
  @@index([userId])
}

model Usage {
  id        String   @id @default(cuid())
  userId    String
  month     String   // "2025-06" format
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

model PerformanceFixerAudit {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  url        String
  industry   String?
  analyzedAt DateTime @default(now())

  lcp  Float
  fid  Float?
  inp  Float?
  cls  Float

  lcpScore    Int
  fidScore    Int?
  clsScore    Int
  overallScore   Int
  projectedScore Int

  revenueLoss      Float?
  potentialRevenue Float?
  fixTime          Int
  fixCost          Float

  fixes           String
  totalFixes      Int
  extendedMetrics String? @db.Text

  industryAvg  Int?
  industryRank Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiFixes AIFixGeneration[]

  @@index([userId])
}

model AIFixGeneration {
  id      String                @id @default(cuid())
  auditId String
  audit   PerformanceFixerAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  fixType         String
  language        String
  beforeCode      String
  afterCode       String
  description     String
  estimatedImpact Int
  applied         Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([auditId])
}

model ContentOptimization {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  content       String  @db.Text
  targetKeyword String
  contentUrl    String?

  detectedIntent    String
  intentMatchScore  Int
  intentSuggestions String @db.Text

  entities            String @db.Text
  entityScore         Int
  missingEntities     String @db.Text
  entityRelationships String @db.Text

  lsiKeywords String @db.Text
  missingLsi  String @db.Text
  lsiScore    Int

  recommendedSchema String
  schemaJsonLd      String @db.Text

  mainTopic          String
  subtopicsCovered   String @db.Text
  subtopicsMissing   String @db.Text
  topicCoverageScore Int

  pillarSuggestion    String?
  clusterSuggestions  String? @db.Text
  internalLinkingOps  String? @db.Text

  experienceScore Int
  expertiseScore  Int
  authorityScore  Int
  trustScore      Int
  eeatOverall     Int

  overallScore       Int
  rewriteSuggestions String @db.Text
  improvements       String @db.Text

  analyzedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fixes ContentOptimizationFix[]

  @@index([userId])
}

model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  description   String
  content       String    @db.Text
  contentType   String    @default("markdown") // "html" | "markdown"
  category      String
  tags          String    @default("") // comma-separated
  featuredImage String?
  readingTime   String    @default("5 min read")
  published     Boolean   @default(false)
  publishedAt   DateTime?
  scheduledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
  @@index([published, publishedAt])
}

model ContentOptimizationFix {
  id             String              @id @default(cuid())
  optimizationId String
  optimization   ContentOptimization @relation(fields: [optimizationId], references: [id], onDelete: Cascade)

  category   String
  priority   String
  issue      String
  suggestion String  @db.Text
  beforeText String? @db.Text
  afterText  String? @db.Text
  applied    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([optimizationId])
}

model ContentIdeaProject {
  id             String @id @default(cuid())
  userId         String
  user           User   @relation("ContentIdeaProjects", fields: [userId], references: [id], onDelete: Cascade)

  name           String
  industry       String
  targetAudience String
  seedKeywords   String @db.Text
  competitors    String @db.Text

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  ideas     ContentIdea[]
  calendar  ContentCalendar[]

  @@index([userId])
}

model ContentIdea {
  id        String             @id @default(cuid())
  projectId String
  project   ContentIdeaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  slug        String
  description String?

  primaryKeyword  String
  relatedKeywords String @db.Text
  searchVolume    Int
  difficulty      Int
  cpc             Float?

  contentType     String
  estimatedLength Int
  sections        String @db.Text

  entitiesNeeded String @db.Text
  lsiKeywords    String @db.Text
  semanticGaps   String @db.Text

  eeatScore        Int
  competitorCount  Int
  opportunityScore Int

  status     String    @default("idea")
  assignedTo String?
  dueDate    DateTime?

  aiOutline String? @db.Text
  aiIntro   String? @db.Text

  pinned Boolean @default(false)
  notes  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([difficulty])
  @@index([opportunityScore])
}

model CompetitorAnalysis {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("CompetitorAnalyses", fields: [userId], references: [id], onDelete: Cascade)

  domainUrl  String
  domainName String

  estimatedTraffic Int
  domainAuthority  Float
  pageAuthority    Float
  backlinksTotal   Int
  backlinksNew     Int

  topKeywords  String @db.Text
  keywordCount Int
  brandKeywords String @db.Text

  topPages         String @db.Text
  contentCount     Int
  avgContentLength Int

  topBacklinks    String @db.Text
  backlinksSource String @db.Text

  gapKeywords     String @db.Text
  missingEntities String @db.Text
  contentOpps     String @db.Text

  aiInsights  String? @db.Text

  dataQuality    String   @default("high")
  lastAnalyzedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([domainUrl])
}

model CompetitorComparison {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("CompetitorComparisons", fields: [userId], references: [id], onDelete: Cascade)

  name       String
  yourDomain String
  competitors String @db.Text

  comparisonData String @db.Text
  keywordOverlap String @db.Text
  uniqueToYou    String @db.Text
  uniqueToThem   String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ContentCalendar {
  id        String             @id @default(cuid())
  projectId String
  project   ContentIdeaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ideaId    String?

  title       String
  publishDate DateTime
  status      String   @default("planned")
  notes       String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([publishDate])
}
