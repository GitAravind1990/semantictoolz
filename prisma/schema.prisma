generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
  PAUSED
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription      Subscription?
  usage             Usage[]
  performanceAudits PerformanceFixerAudit[]

  @@index([clerkId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  paddleSubscriptionId String             @unique
  paddleCustomerId     String
  paddlePriceId        String
  paddleTransactionId  String?
  status               SubscriptionStatus @default(ACTIVE)
  plan                 Plan
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([paddleSubscriptionId])
  @@index([userId])
}

model Usage {
  id        String   @id @default(cuid())
  userId    String
  month     String   // "2025-06" format
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

model PerformanceFixerAudit {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  url        String
  industry   String?
  analyzedAt DateTime @default(now())

  lcp  Float
  fid  Float?
  inp  Float?
  cls  Float

  lcpScore    Int
  fidScore    Int?
  clsScore    Int
  overallScore   Int
  projectedScore Int

  revenueLoss      Float?
  potentialRevenue Float?
  fixTime          Int
  fixCost          Float

  fixes      String
  totalFixes Int

  industryAvg  Int?
  industryRank Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiFixes AIFixGeneration[]

  @@index([userId])
}

model AIFixGeneration {
  id      String                @id @default(cuid())
  auditId String
  audit   PerformanceFixerAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  fixType         String
  language        String
  beforeCode      String
  afterCode       String
  description     String
  estimatedImpact Int
  applied         Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([auditId])
}
